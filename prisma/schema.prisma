generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                String   @id @default(cuid())
  title             String
  slug              String   @unique
  description       String
  category          String
  tags              String[]
  thumbnailUrl      String
  videoUrl          String?
  duration          Int?
  cloudinaryPublicId String?
  featured          Boolean  @default(false)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id         String   @id @default(cuid())
  name       String
  percentage Int
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id             String   @id @default(cuid())
  clientName     String
  clientPosition String
  message        String
  avatar         String?
  featured       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("Unread")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id             String   @id @default(cuid())
  brandName      String   @default("Aman Creative")
  tagline        String   @default("Creating Stories That Inspire and Content That Performs")
  heroTitle      String
  heroSubtitle   String
  heroImage      String?
  aboutImage     String?
  aboutText      String
  ownerName      String   @default("Aman Weldemariam")
  email          String
  phone          String
  whatsapp       String?
  github         String
  linkedin       String
  instagram      String
  tiktok         String?
  youtube        String?
  heroCtaText    String?
  heroCtaLink    String?
  heroSecondaryCtaText String?
  heroSecondaryCtaLink String?
  projectsCompleted Int?
  footerText     String
  primaryColor   String
  secondaryColor String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  type      String
  url       String
  publicId  String
  thumbnailUrl String?
  previewUrl String?
  format    String?
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
